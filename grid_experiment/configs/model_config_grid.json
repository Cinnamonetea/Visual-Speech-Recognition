{
  "vocab_size": 55,
  "d_model": 48,
  "nhead": 2,
  "num_layers": 2,
  "num_encoder_layers": 2,
  "num_decoder_layers": 1,
  "dim_feedforward": 96,
  "dropout": 0.3,
  "max_frames": 75,
  "max_tokens": 8,

  "_vocab_comment": "52 words + PAD(0) + BOS(1) + EOS(2) = 55",
  "_frames_comment": "GRID videos are 75 frames at 25fps = 3sec",
  "_tokens_comment": "6 words + BOS + EOS = 8",

  "encoder": {
    "stem_channels": 24,
    "drop_path_rate": 0.1,

    "mbconv_blocks": [
      {
        "in_channels": 24,
        "out_channels": 48,
        "kernel_size": 3,
        "stride": 2,
        "expand_ratio": 2,
        "se_ratio": 0.25,
        "use_se": true
      },
      {
        "in_channels": 48,
        "out_channels": 64,
        "kernel_size": 3,
        "stride": 2,
        "expand_ratio": 2,
        "se_ratio": 0.25,
        "use_se": true
      }
    ]
  }
}
