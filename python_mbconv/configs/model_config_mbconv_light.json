{
  "vocab_size": 1200,
  "d_model": 64,
  "nhead": 4,
  "num_layers": 4,
  "dim_feedforward": 128,
  "dropout": 0.6,
  "max_frames": 40,
  "max_tokens": 12,

  "encoder": {
    "stem_channels": 32,
    "drop_path_rate": 0.3,

    "mbconv_blocks": [
      {
        "in_channels": 32,
        "out_channels": 32,
        "kernel_size": 3,
        "stride": 1,
        "expand_ratio": 1,
        "se_ratio": 0.25,
        "use_se": true,
        "_comment": "Refine stem, skip connection, ~2K params"
      },
      {
        "in_channels": 32,
        "out_channels": 64,
        "kernel_size": 3,
        "stride": 2,
        "expand_ratio": 3,
        "se_ratio": 0.25,
        "use_se": true,
        "_comment": "Downsample 32x48 → 16x24, expand=3 (не 4), ~14K params"
      },
      {
        "in_channels": 64,
        "out_channels": 96,
        "kernel_size": 3,
        "stride": 2,
        "expand_ratio": 3,
        "se_ratio": 0.25,
        "use_se": true,
        "_comment": "Downsample 16x24 → 8x12, final 96 channels, ~46K params"
      }
    ]
  }
}
